---
import Layout from '../components/Layout.astro'
import ProjectsList from '../components/ProjectsList.astro'
import { getCollection } from 'astro:content'
import { siteConfig } from '../config'

const allProjects = await getCollection('projects')
const projects = allProjects.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
---

<Layout title="Projects" url={`${siteConfig.siteUrl}/projects`} active="projects">
  <ProjectsList projects={projects} className="mt-22.5" />
</Layout>
