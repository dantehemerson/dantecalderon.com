---
import Layout from '../components/Layout.astro'
import MDXContainer from '../components/MDXContainer.astro'
import HeaderHome from '../components/HeaderHome.astro'
import AboutContent from '../../content/sections/about.mdx'
import ProjectsList from '../components/ProjectsList.astro'
import { getCollection } from 'astro:content'
import { siteConfig } from '../config'

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
)
---

<Layout title="Dante Calderon" url={siteConfig.siteUrl}>
  <HeaderHome />
  <MDXContainer>
    <AboutContent />
  </MDXContainer>
  <ProjectsList projects={projects} className="mt-6" />
</Layout>
