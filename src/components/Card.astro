---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { formatDate } from '@/helpers/date'

export interface Props {
  title: string
  date: Date
  image?: ImageMetadata | string
  excerpt: string
  slug: string
}

const { title, date, image, excerpt, slug } = Astro.props
console.log('IMAGE OF ', title, image)
---

<a
  href={`/blog/${slug}`}
  class="flex items-start text-left flex-col py-5 px-2 m-0 rounded-sm no-underline hover:bg-[#f2f2f2] hover:shadow-[-16px_0_0_0_#f2f2f2,16px_0_0_0_#f2f2f2] md:flex-row"
>
  {
    image && (
      <div class="overflow-hidden w-full m-0 md:w-1/3">
        <Image
          src={image as any}
          alt={title}
          class="w-full rounded-sm"
          inferSize
          widths={[400]}
          layout="fixed"
          sizes={`(max-width: 400px) 100vw, 400px`}
        />
      </div>
    )
  }
  <div class="w-full h-full m-0 max-w-140 pt-3 md:pl-7.5 md:pt-0 md:w-3/4 md:max-w-full">
    <h3 class="font-serif text-[#052d3e] m-0 transition duration-300 text-xl font-semibold">
      {title}
    </h3>
    <p class="m-0 text-sm pt-1 sm:text-[0.8rem]">{excerpt}</p>
    <p class="text-[#727272] text-[11px] m-0 py-3 px-0 pb-1.5">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
    </p>
  </div>
</a>
