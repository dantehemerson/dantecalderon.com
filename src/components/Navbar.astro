---
import { siteConfig } from '../config'

export interface Props {
  active?: string
  menu?: typeof siteConfig.menu
  title?: string
  subtitle?: string
}

const {
  active = '',
  menu = siteConfig.menu,
  title = siteConfig.title,
  subtitle = siteConfig.subtitle,
} = Astro.props

const icons: Record<string, string> = {
  home: `<svg class="icon-item" version="1.1" viewBox="0 0 36 36" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true" role="img"><path d="M33.71,17.29l-15-15a1,1,0,0,0-1.41,0l-15,15a1,1,0,0,0,1.41,1.41L18,4.41,32.29,18.71a1,1,0,0,0,1.41-1.41Z"/><path d="M28,32h-5V22H13V32H8V18L6,20V32a2,2,0,0,0,2,2h7V24h6V34h7a2,2,0,0,0,2-2V19.76l-2-2Z"/></svg>`,
  blog: `<svg class="icon-item" version="1.1" viewBox="0 0 36 36" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true" role="img"><polygon points="9.6 22.88 9.6 10.6 24.4 10.6 25.98 9 8 9 8 22.88 9.6 22.88"/><path d="M6,7H30V23h2V6.5A1.5,1.5,0,0,0,30.5,5H5.5A1.5,1.5,0,0,0,4,6.5V23H6Z"/><path d="M1,25v3.4A2.6,2.6,0,0,0,3.6,31H32.34a2.6,2.6,0,0,0,2.6-2.6V25Zm32,3.4a.6.6,0,0,1-.6.6H3.56a.6.6,0,0,1-.6-.6V26.53h9.95a1.64,1.64,0,0,0,1.5,1h7.13a1.64,1.64,0,0,0,1.5-1H33Z"/></svg>`,
  projects: `<svg class="icon-item" version="1.1" viewBox="0 0 36 36" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true" role="img"><path d="M32,28a0,0,0,0,1,0,0H4V21.32a7.1,7.1,0,0,1-2-1.43V28a2,2,0,0,0,2,2H32a2,2,0,0,0,2-2V19.89a6.74,6.74,0,0,1-2,1.42Z"/><path d="M25,22.4a1,1,0,0,0,1-1V15.94H24V18H14v2H24v1.4A1,1,0,0,0,25,22.4Z"/><path d="M33,6H24V4.38A2.42,2.42,0,0,0,21.55,2h-7.1A2.42,2.42,0,0,0,12,4.38V6H3A1,1,0,0,0,2,7v8a5,5,0,0,0,5,5h3v1.4a1,1,0,0,0,2,0V15.94H10V18H7a3,3,0,0,1-3-3V8H32v7a3,3,0,0,1-3,3H28v2h1a5,5,0,0,0,5-5V7A1,1,0,0,0,33,6ZM22,6H14V4.43A.45.45,0,0,1,14.45,4h7.11a.43.43,0,0,1,.44.42Z"/></svg>`,
}
---

<nav
  id="Navbar"
  class="h-15.25 flex justify-center fixed left-0 top-0 w-full z-10 shadow-[0px_1px_0px_0px_#e8e8e8] transition-colors"
  class:list={{ 'bg-transparent': active === '' }}
>
  <div
    id="navOverlay"
    class="fixed left-[900%] top-0 w-[900%] h-full transition-none md:hidden"
    aria-hidden="true"
  >
  </div>

  <div class="flex items-center justify-between px-5 w-225 max-w-full">
    <a
      href="/"
      id="navLogo"
      class="flex items-center rounded-[3px] pr-0.75 hover:bg-[rgba(195,195,195,0.22)]"
    >
      <img
        src="/logo.png"
        alt={subtitle}
        class="w-8 h-8 rounded-[3px] mr-2"
        width="32"
        height="32"
      />
      <p class="capitalize font-black text-body m-0">{title}</p>
    </a>

    <div>
      <button
        id="navbarToggler"
        aria-label="Navbar Toggle"
        class="md:hidden relative w-7.5 h-4.5 top-1 bg-transparent border-0 p-0 cursor-pointer z-[100] focus:outline-none"
      >
        <span
          class="block relative w-7.5 h-0.5 bg-[rgba(0,0,0,0.88)] rounded-none transition-all duration-250 top-2 after:content-[''] after:absolute after:left-0 after:h-0.5 after:w-7.5 after:rounded-none after:bg-[rgba(0,0,0,0.88)] after:transition-all after:duration-250 after:-top-2 before:content-[''] before:absolute before:left-0 before:h-0.5 before:w-7.5 before:rounded-none before:bg-[rgba(0,0,0,0.88)] before:transition-all before:duration-250 before:top-2"
        ></span>
      </button>

      <ul
        id="navMenu"
        class="z-30 list-none absolute mb-0 top-0 shadow-[0px_0px_0px_1px_#f3f3f3] w-3/4 max-w-[420px] h-screen flex-col justify-center items-center bg-white transition-[right] duration-400 md:static md:flex-row md:bg-transparent md:shadow-none md:w-auto md:h-auto md:max-w-none md:right-auto md:flex md:opacity-100 md:visible -right-[102%]"
      >
        {
          menu.map(item => (
            <li class="w-[98%] md:w-auto md:ml-0.5 md:border-t-0 md:last:border-b-0">
              <a
                href={item.to}
                class="text-[15px] font-semibold py-2.5 px-2 text-center rounded-[3px] flex items-center justify-center hover:!bg-[rgba(195,195,195,0.22)] md:py-1.5 md:!px-4 no-underline text-body"
              >
                <span class="pr-1 relative w-5.25 h-4.25">
                  <Fragment set:html={icons[item.icon]} />
                </span>
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>

<style>
  #Navbar.noTop {
    background-color: white !important;
  }

  #Navbar.menu-open #navMenu {
    right: 0 !important;
  }

  #Navbar.menu-open #navOverlay {
    left: 0 !important;
    background-color: rgb(0 0 0 / 0.3);
    z-index: 20;
    transition: background-color 400ms;
  }

  #navbarToggler.open > span {
    background-color: transparent;
  }
  #navbarToggler.open > span::before {
    top: 0;
    transform: translateY(8px) rotate(-45deg);
  }
  #navbarToggler.open > span::after {
    top: 0;
    transform: translateY(-8px) rotate(45deg);
  }
</style>

<script>
  function initNavbar() {
    var nav = document.getElementById('Navbar')
    var menu = document.getElementById('navMenu')
    var overlay = document.getElementById('navOverlay')
    var toggler = document.getElementById('navbarToggler')
    var logo = document.getElementById('navLogo')

    if (!nav || !menu || !overlay || !toggler || !logo) return

    var menuOpen = false

    function closeMenu() {
      menuOpen = false
      nav.classList.remove('menu-open')
      toggler.classList.remove('open')
    }

    function openMenu() {
      menuOpen = true
      nav.classList.add('menu-open')
      toggler.classList.add('open')
    }

    function toggleMenu() {
      if (menuOpen) closeMenu()
      else openMenu()
    }

    function onScroll() {
      nav.classList.toggle('noTop', window.scrollY > 5)
    }

    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })

    toggler.addEventListener('click', toggleMenu)
    overlay.addEventListener('click', closeMenu)

    logo.addEventListener('click', closeMenu)

    var links = menu.querySelectorAll('a')
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMenu)
    }

    var mq = window.matchMedia('(min-width: 768px)')
    function handleBreakpoint(e) {
      if (e.matches) closeMenu()
    }
    mq.addEventListener('change', handleBreakpoint)
  }

  document.addEventListener('astro:page-load', initNavbar)
  initNavbar()
</script>
