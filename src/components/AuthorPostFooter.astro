---
export interface Props {
  avatar?: string
  make?: boolean
}

const { avatar, make = false } = Astro.props
---

<div class="flex mb-3.25 mt-5 max-w-[770px] mx-auto flex-col items-center md:flex-row md:items-inherit">
  <div>
    {avatar && (
      <img
        alt="Author post avatar"
        src={avatar}
        class="m-0 w-22.5 h-22.5 rounded-[3px] md:w-33.5 md:h-33.5 md:mr-5.25"
      />
    )}
  </div>
  <div class="flex flex-col justify-center items-center pt-3.5 md:items-inherit md:pt-0 font-sans">
    <p class="text-sm uppercase font-normal text-[#767676] m-0">
      {make ? 'Made with ❤' : 'Written'} by
    </p>
    <a href="/#about-me" class="m-0 text-[21px] leading-none font-semibold text-[#292929] no-underline md:text-[23px]">
      Dante Calderón
    </a>
    <p class="text-[rgba(0,0,0,0.54)] text-sm font-normal pt-1.25 m-0 text-center md:text-left">
      Hi, I'm Dante Calderón, web developer. Click{' '}
      <a href="/#about-me" class="default">
        here
      </a>{' '}
      if you want know more about me.
    </p>
  </div>
</div>
