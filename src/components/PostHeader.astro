---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import AuthorPost from './AuthorPost.astro'

export interface Props {
  title: string
  date: Date
  avatar?: string
  image?: ImageMetadata
  externalImage?: string
}

const { title, date, avatar, image, externalImage } = Astro.props
---

<div class="max-w-225 mx-auto mb-6.5">
  <h1
    id="post_id"
    class="font-serif font-bold leading-10 text-[28px] m-0 px-2.5 sm:text-[28px] md:text-[37px]"
  >
    {title}
  </h1>
  <AuthorPost date={date} avatar={avatar} />
  {image ? <Image src={image} alt={`${title} cover`} class="zoomable w-full" /> : null}
</div>
