<script>
  import 'photoswipe/style.css'
  import { parseSubstackImageUrl } from '@/helpers/media'

  import PhotoSwipeLightbox from 'photoswipe/lightbox'

  function initMediaSystem() {
    // --- Sync pswp-link href to resolved img.src ---
    document.querySelectorAll<HTMLAnchorElement>('.pswp-link').forEach(a => {
      const img = a.querySelector('img')
      if (img) {
        // These fields cannot be generated on build time because rehype plugins run
        // before astro image optimization.
        a.href = img.src

        const dims = parseSubstackImageUrl(img.src)
        const width = img.getAttribute('width') ?? dims?.width
        const height = img.getAttribute('height') ?? dims?.height

        width && (a.dataset.pswpWidth = width)
        height && (a.dataset.pswpHeight = height)
      }
    })

    // --- Init PhotoSwipe ---
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.prose',
      children: '.pswp-link',
      pswpModule: () => import('photoswipe'),
    })
    lightbox.on('uiRegister', function () {
      lightbox.pswp!.ui!.registerElement({
        name: 'caption',
        order: 9,
        tagName: 'div',
        onInit: (el, pswp) => {
          pswp.on('change', () => {
            const currentEl = pswp.currSlide!.data.element
            el.innerHTML = currentEl?.dataset?.caption ?? ''
          })
        },
      })
    })

    lightbox.init()
  }

  document.addEventListener('astro:page-load', initMediaSystem)
  initMediaSystem()
</script>
